#cloud-config
# Ubuntu Server autoinstall for Legacy BIOS / SeaBIOS.
#
# Disk layout:
#   /dev/sda or largest available disk
#   |- partition 1       /boot, ext4, 1 GiB, bootable, outside LVM
#   `- partition 2       LVM PV, all remaining disk space
#      `- vg0
#         |- lv_root     /, ext4, 10 GiB
#         |- lv_home     /home, ext4, 10 GiB
#         |- lv_tmp      /tmp, ext4, 10 GiB
#         |- lv_swap     swap, 1 GiB
#         `- lv_var      /var, ext4, all remaining VG space
#
# Other settings:
#   - Network: DHCP on Ethernet-like interfaces.
#   - Hostname: ubuntu-auto.
#   - User: user / Admin@123!, password stored as SHA-512 crypt hash.
#   - User belongs to sudo group; password SSH login is enabled.
#   - Root password is also Admin@123!, but root SSH login is disabled.
#   - Installs openssh-server, qemu-guest-agent, curl, wget, vim, net-tools, lvm2.
#   - Proxmox note: also enable the VM option with "qm set <VMID> -agent enabled=1".
#
# NoCloud usage:
#   Put this file as "user-data" next to an empty "meta-data" file.
#   Boot parameter example:
#     autoinstall ds=nocloud-net;s=http://SERVER/ubuntu/bios/

autoinstall:
  version: 1
  refresh-installer:
    update: false

  locale: en_US.UTF-8
  keyboard:
    layout: us
    variant: ""

  timezone: Etc/UTC

  source:
    id: ubuntu-server
    search_drivers: false

  network:
    version: 2
    ethernets:
      ethernet-dhcp:
        match:
          name: "e*"
        dhcp4: true
        dhcp6: false

  # Static IP example.
  # To use it, replace the DHCP block above with this block.
  #
  # network:
  #   version: 2
  #   ethernets:
  #     ethernet-static:
  #       match:
  #         name: "e*"
  #       dhcp4: false
  #       dhcp6: false
  #       addresses:
  #         - 172.20.20.200/24
  #       routes:
  #         - to: default
  #           via: 172.20.20.1
  #       nameservers:
  #         addresses:
  #           - 172.20.20.1
  #           - 8.8.8.8
  #         search:
  #           - home.arpa

  apt:
    geoip: false
    fallback: offline-install
    mirror-selection:
      primary:
        - uri: http://archive.ubuntu.com/ubuntu
          arches: [amd64, i386]
        - uri: http://ports.ubuntu.com/ubuntu-ports
          arches: [arm64, armhf, ppc64el, riscv64, s390x]

  identity:
    hostname: ubuntu-auto
    realname: user
    username: user
    password: '$6$codexsalt$APXuT088Gk9leqwK2jqOlxdLtO7xbsfIuvOapi3VaFLEdikpI70ZknwuTzCpUEoqWGCR01NgyZVgeL7Wyz3W3.'
    groups: [adm, sudo]

  ssh:
    install-server: true
    allow-pw: true

  packages:
    - curl
    - wget
    - vim
    - net-tools
    - lvm2
    - sudo
    - qemu-guest-agent

  updates: security

  storage:
    swap:
      size: 0
    config:
      - id: root-disk
        type: disk
        match:
          size: largest
        ptable: msdos
        wipe: superblock-recursive
        preserve: false
        grub_device: true

      - id: boot-partition
        type: partition